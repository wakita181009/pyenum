{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-write.sh",
            "timeout": 120,
            "statusMessage": "format + lint"
          }
        ]
      }
    ]
  }
}
