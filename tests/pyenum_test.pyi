"""Type stubs for the ``pyenum_test`` cdylib fixture.

Kept in sync with ``crates/pyenum-test/src/lib.rs``. Updating the Rust
side requires matching edits here — there is no automatic stub generator
for enums built through the functional ``enum.Enum("Name", members)``
API.
"""

from __future__ import annotations

import enum

