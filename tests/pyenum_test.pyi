def greeting_roundtrip(g: Greeting) -> Greeting: ...
def language_roundtrip(l: Language) -> Language: ...
def permission_roundtrip(p: Permission) -> Permission: ...
def bitperms_roundtrip(p: BitPerms) -> BitPerms: ...

