    Write = ...
    Execute = ...

class BitPerms(enum.IntFlag):
    Read = ...
    Write = ...
    Execute = ...
    Admin = ...

class UnpicklableColor(enum.Enum):
    Red = ...
    Green = ...
    Blue = ...

